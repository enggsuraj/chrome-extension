{
  "manifest_version": 3,
  "name": "QuickIP",
  "version": "1.0.2",
  "description": "Get user IP address, current location, time, and date with QuickIP Chrome extension.",
  "icons": {
    "16": "assets/QuickIP.png",
    "48": "assets/QuickIP.png",
    "128": "assets/QuickIP.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/QuickIP.png",
      "24": "assets/QuickIP.png",
      "32": "assets/QuickIP.png"
    },
    "default_title": "Click Here ",
    "default_popup": "popup.html"
  },
  "host_permissions": ["https://ipinfo.io/*"]
}
